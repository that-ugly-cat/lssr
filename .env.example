# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
# Fernet key for per-user Anthropic key encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-in-production
DATABASE_URL=sqlite:////app/data/lssr.db
# URL of the paper2md service used at step 7 (full-text → markdown)
PAPER2MD_URL=http://localhost:8008
