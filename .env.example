# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
# Fernet key for per-user Anthropic key encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-in-production
DATABASE_URL=sqlite:////app/data/lssr.db
# paper2md service used at step 7 (PDF → markdown). Point this at the deployed
# instance, e.g. https://paper2md.borant.eu — the localhost default only works if
# paper2md runs on the same host.
PAPER2MD_URL=http://localhost:8008
# Optional but recommended: an issued paper2md key (X-API-Key). Without it the
# upload cap is 10MB; with it, 50MB — papers routinely exceed the anonymous cap.
PAPER2MD_API_KEY=
# Email Unpaywall is told to contact at step 6. Defaults to the workspace owner's.
UNPAYWALL_EMAIL=
# Publisher text-and-data-mining APIs — the last layer of full-text retrieval,
# tried only for DOIs with that publisher's prefix, and only when set. Each is
# the sanctioned route for systematic retrieval under an existing subscription.
# These are only a SERVER-WIDE FALLBACK: users normally set their own in
# Profile → Publisher full-text access, since the entitlement follows the person.
# Elsevier/ScienceDirect: free key from https://dev.elsevier.com. The key alone
# reaches open-access articles; entitled subscription content also needs an
# institutional token (issued to the institution) or a call from its IP range.
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=
# Springer Nature open-access API: free key from https://dev.springernature.com
SPRINGER_API_KEY=
# Wiley TDM client token, from a Wiley Online Library account with entitlement
WILEY_TDM_TOKEN=
